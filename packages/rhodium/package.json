{
  "name": "rhodium",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities.d.ts",
      "import": "./dist/capabilities.js"
    },
    "./graph": {
      "types": "./dist/graph.d.ts",
      "import": "./dist/graph.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly && bun build ./src/index.ts ./src/core.ts ./src/capabilities.ts ./src/graph.ts ./src/testing.ts --outdir ./dist --target node --format esm",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "rhodium-core": "workspace:*",
    "rhodium-capabilities": "workspace:*",
    "rhodium-graph": "workspace:*",
    "rhodium-testing": "workspace:*"
  }
}
