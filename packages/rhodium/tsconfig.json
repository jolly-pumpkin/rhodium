    "rootDir": "./src",
    "composite": true,
    "paths": {
      "rhodium-core": ["../core/src/index.ts"],
      "rhodium-capabilities": ["../capabilities/src/index.ts"],
      "rhodium-graph": ["../graph/src/index.ts"],
      "rhodium-testing": ["../testing/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
